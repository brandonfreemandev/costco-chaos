<?php
// ============================================================
//  Costco Chaos — Ollama Cloud Proxy
//  Deploy this file to your InfinityFree server at /api/chat.php
//
//  SETUP:
//  1. Copy this file to chat.php (same folder)
//  2. Replace YOUR_OLLAMA_KEY_HERE with your key from ollama.com/settings/keys
//  3. Update ALLOWED_ORIGIN to your actual deployed domain
//  4. Never commit chat.php to git — only this example file belongs in the repo
// ============================================================

define('OLLAMA_API_KEY', 'YOUR_OLLAMA_KEY_HERE');
define('OLLAMA_ENDPOINT', 'https://ollama.com/api/chat');
define('OLLAMA_MODEL',    'gemma4:31b');

// ============================================================
//  CORS — update to your actual game domain before going live
//  e.g. 'https://costco-chaos.infinityfreeapp.com'
//  Use '*' only for local testing.
// ============================================================
define('ALLOWED_ORIGIN', '*');

header('Access-Control-Allow-Origin: '  . ALLOWED_ORIGIN);
header('Access-Control-Allow-Methods: POST, OPTIONS');
header('Access-Control-Allow-Headers: Content-Type');
header('Content-Type: application/json');

if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
    http_response_code(204);
    exit;
}

if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    http_response_code(405);
    echo json_encode(['error' => 'Method not allowed']);
    exit;
}

$body = json_decode(file_get_contents('php://input'), true);
if (!isset($body['messages']) || !is_array($body['messages'])) {
    http_response_code(400);
    echo json_encode(['error' => 'Missing messages array']);
    exit;
}

$payload = json_encode([
    'model'    => OLLAMA_MODEL,
    'messages' => $body['messages'],
    'stream'   => false,
]);

$ch = curl_init(OLLAMA_ENDPOINT);
curl_setopt_array($ch, [
    CURLOPT_RETURNTRANSFER => true,
    CURLOPT_POST           => true,
    CURLOPT_POSTFIELDS     => $payload,
    CURLOPT_HTTPHEADER     => [
        'Content-Type: application/json',
        'Authorization: Bearer ' . OLLAMA_API_KEY,
    ],
    CURLOPT_TIMEOUT        => 30,
]);

$response = curl_exec($ch);
$httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
$curlErr  = curl_error($ch);
curl_close($ch);

if ($curlErr) {
    http_response_code(502);
    echo json_encode(['error' => 'Upstream request failed', 'detail' => $curlErr]);
    exit;
}

$data = json_decode($response, true);

if (isset($data['message']['content'])) {
    http_response_code(200);
    echo json_encode(['content' => $data['message']['content']]);
} else {
    http_response_code($httpCode ?: 502);
    echo json_encode(['error' => 'Unexpected upstream response', 'raw' => $data]);
}
